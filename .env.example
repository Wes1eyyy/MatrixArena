# MatrixArena API Key Configuration
# Copy this file to .env and fill in your actual keys

# OpenRouter — single key to access all models in the arena
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: identify your app in OpenRouter request headers
# OPENROUTER_APP_NAME=MatrixArena
# OPENROUTER_SITE_URL=https://github.com/Wes1eyyy/MatrixArena

# Optional: Number of evaluation cycles to run (default: 5)
NUM_CYCLES=5
